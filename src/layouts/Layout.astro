---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Bard's Freaky Faces — AI-generated character art by Bård Ionson" } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/images/cropped-digital_self_sm-e1645391047337.jpg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title} | Bard's Freaky Faces</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="scanlines" aria-hidden="true"></div>
  <nav>
    <a href="/" class="nav-logo">BARD'S FREAKY FACES</a>
    <ul>
      <li><a href="/">HOME</a></li>
      <li><a href="/gallery">GALLERY</a></li>
      <li><a href="/trippin">TRIPPIN</a></li>
      <li><a href="/about">ABOUT</a></li>
      <li><a href="https://opensea.io/collection/bards-freaky-faces" target="_blank" rel="noopener">OPENSEA ↗</a></li>
    </ul>
  </nav>
  <main>
    <slot />
  </main>
  <footer>
    <p>© Bård Ionson — Only 50 ever created — <a href="https://opensea.io/collection/bards-freaky-faces" target="_blank" rel="noopener">View on OpenSea</a></p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #080808;
    --bg2: #0f0f0f;
    --green: #00ff41;
    --pink: #ff0090;
    --cyan: #00e5ff;
    --yellow: #ffea00;
    --text: #e8e8e8;
    --muted: #999;
    --font-head: 'Space Grotesk', sans-serif;
    --font-mono: 'Space Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-head);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* CRT scanline overlay */
  .scanlines {
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 1px solid #1a1a1a;
    position: sticky;
    top: 0;
    background: rgba(8,8,8,0.95);
    backdrop-filter: blur(8px);
    z-index: 100;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--green);
    text-decoration: none;
    letter-spacing: 0.1em;
    text-shadow: 0 0 10px var(--green);
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    color: var(--muted);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    transition: color 0.2s;
  }

  nav ul a:hover { color: var(--green); }

  main { min-height: calc(100vh - 140px); }

  footer {
    border-top: 1px solid #1a1a1a;
    padding: 1.5rem 2rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  footer a { color: var(--green); text-decoration: none; }

  h1, h2, h3 { font-family: var(--font-head); font-weight: 900; }

  a { color: var(--cyan); }

  /* Glitch effect for images */
  @keyframes glitch-1 {
    0%, 100% { clip-path: inset(0 0 95% 0); transform: translate(-2px, 0); }
    20% { clip-path: inset(30% 0 50% 0); transform: translate(2px, 0); }
    40% { clip-path: inset(70% 0 10% 0); transform: translate(-1px, 0); }
    60% { clip-path: inset(10% 0 80% 0); transform: translate(3px, 0); }
    80% { clip-path: inset(60% 0 20% 0); transform: translate(-2px, 0); }
  }
  @keyframes glitch-2 {
    0%, 100% { clip-path: inset(80% 0 5% 0); transform: translate(2px, 0); }
    20% { clip-path: inset(5% 0 80% 0); transform: translate(-2px, 0); }
    40% { clip-path: inset(40% 0 40% 0); transform: translate(1px, 0); }
    60% { clip-path: inset(90% 0 2% 0); transform: translate(-3px, 0); }
    80% { clip-path: inset(20% 0 70% 0); transform: translate(2px, 0); }
  }

  .face-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: #0f0f0f;
    border: 1px solid #1a1a1a;
    transition: border-color 0.3s;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .face-card:hover { border-color: var(--green); }

  .face-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .face-card:hover img { transform: scale(1.03); }

  .face-card::before,
  .face-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: inherit;
    opacity: 0;
    pointer-events: none;
  }

  .face-card:hover::before {
    background: url('') center/cover,
      linear-gradient(transparent, transparent);
    opacity: 0.6;
    animation: glitch-1 0.4s steps(1) infinite;
    mix-blend-mode: exclusion;
    background-color: var(--pink);
    z-index: 2;
  }

  .face-card:hover::after {
    background-color: var(--cyan);
    opacity: 0.4;
    animation: glitch-2 0.4s steps(1) infinite;
    mix-blend-mode: exclusion;
    z-index: 3;
  }

  .face-label {
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    background: var(--bg2);
  }

  .face-card:hover .face-label { color: var(--green); }

  @media (max-width: 768px) {
    nav { flex-direction: column; gap: 1rem; padding: 1rem; }
    nav ul { gap: 1rem; flex-wrap: wrap; justify-content: center; }
  }
</style>
